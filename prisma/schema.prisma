generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum RoleType {
  FULL_TIME
  INTERN
}

enum AbsenceType {
  VACATION
  DAY_OFF
}

enum ReleaseStatus {
  PLANNED
  PLANNING
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum SprintStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

enum FeatureLifecycleStatus {
  ACTIVE
  CANCELLED
}

enum StoryStatus {
  BACKLOG
  SPRINT_BACKLOG
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ImpedimentStatus {
  OPEN
  RESOLVED
}

model SquadMember {
  id        String    @id @default(cuid())
  name      String
  roleType  RoleType
  active    Boolean   @default(true)
  absences  Absence[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Absence {
  id        String      @id @default(cuid())
  memberId  String
  member    SquadMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      AbsenceType
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Release {
  id                        String        @id @default(cuid())
  name                      String
  objective                 String
  description               String?
  startDate                 DateTime
  endDate                   DateTime
  defaultSprintLengthBusinessDays Int   @default(10)
  meetingPercentage         Float         @default(0)
  supportPercentage         Float         @default(0)
  status                    ReleaseStatus @default(PLANNED)
  sprints                   Sprint[]
  features                  Feature[]
  estimateBaseline          ReleaseEstimateBaseline?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
}

model ReleaseEstimateBaseline {
  id          String                        @id @default(cuid())
  releaseId    String                        @unique
  release      Release                       @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  capturedAt   DateTime                      @default(now())
  items        ReleaseEstimateBaselineItem[]

  @@index([releaseId])
}

model ReleaseEstimateBaselineItem {
  id            String                    @id @default(cuid())
  baselineId    String
  baseline      ReleaseEstimateBaseline   @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  storyId       String
  storyPoints   Float?
  estimatedDays Float?

  @@unique([baselineId, storyId])
  @@index([storyId])
}

model Sprint {
  id         String        @id @default(cuid())
  releaseId  String
  release    Release       @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  name       String
  goal       String?
  startDate  DateTime
  endDate    DateTime
  status     SprintStatus  @default(PLANNED)
  stories    Story[]
  leakageOrigins LeakageHistory[] @relation("LeakageOriginSprint")
  leakageDestinations LeakageHistory[] @relation("LeakageDestinationSprint")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Feature {
  id              String                 @id @default(cuid())
  releaseId       String?
  release         Release?               @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  lifecycleStatus FeatureLifecycleStatus @default(ACTIVE)
  stories         Story[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([releaseId])
}

model Story {
  id                 String      @id @default(cuid())
  featureId          String
  feature            Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  currentSprintId    String?
  currentSprint      Sprint?     @relation(fields: [currentSprintId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  acceptanceCriteria String?
  storyPoints        Float?
  estimatedDays      Float?
  status             StoryStatus @default(BACKLOG)
  leakageHistory     LeakageHistory[]
  impediments        Impediment[]
  estimateChanges    EstimateChange[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([featureId])
  @@index([currentSprintId])
}

model EstimateChange {
  id           String   @id @default(cuid())
  storyId      String
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  field        String
  oldValue     Float?
  newValue     Float?
  changeReason String?
  timestamp    DateTime @default(now())

  @@index([storyId])
  @@index([timestamp])
}

model Impediment {
  id              String           @id @default(cuid())
  title           String
  description     String?
  reportedDate    DateTime
  resolutionDate  DateTime?
  resolutionNotes String?
  status          ImpedimentStatus @default(OPEN)
  affectedStories Story[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([reportedDate])
}

model LeakageHistory {
  id                  String      @id @default(cuid())
  storyId             String
  story               Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  originSprintId      String
  originSprint        Sprint      @relation("LeakageOriginSprint", fields: [originSprintId], references: [id], onDelete: Cascade)
  destinationSprintId String
  destinationSprint   Sprint      @relation("LeakageDestinationSprint", fields: [destinationSprintId], references: [id], onDelete: Cascade)
  eventDate           DateTime    @default(now())
  statusAtEvent       StoryStatus

  @@index([storyId])
  @@index([originSprintId])
  @@map("leakage_history")
}

model AppSettings {
  id                   String   @id @default(cuid())
  workingHoursFullTime Float    @default(8)
  workingHoursIntern   Float    @default(6)
  standardDayHours     Float    @default(8)
  mcpHost              String   @default("localhost")
  mcpPort              Int      @default(3333)
  mcpEnabled           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
